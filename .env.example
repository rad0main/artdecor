APP_NAME=ArtDecor
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=artdecor
DB_USERNAME=artdecor
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.yandex.ru
MAIL_PORT=465
MAIL_USERNAME=info@skinali.moscow
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=info@skinali.moscow
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_ADDRESS=info@skinali.moscow

VITE_APP_NAME="${APP_NAME}"

# Yandex Cloud Object Storage
YC_KEY_ID=
YC_KEY_SECRET=
YC_BUCKET=artdecor-images
YC_REGION=ru-central1
YC_CDN_URL=

# Yandex Disk API
YANDEX_DISK_TOKEN=

FILESYSTEM_CLOUD=yandex-cloud

TELEGRAM_BOT_TOKEN=
